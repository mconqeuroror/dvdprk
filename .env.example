# Copy to `.env.local` (Next.js) and/or `.env` (Prisma CLI). Never commit real secrets.

# --- Postgres (required for DB-backed admin + site content) ---
# Use postgresql:// or postgres:// — add ?sslmode=disable if your host needs it.
DATABASE_URL=

# --- Seed (`npm run db:seed`) — password hash for admin row ---
ADMIN_PASSWORD=adminDVd2340@
ADMIN_SEED_USERNAME=adminDvd
ADMIN_SEED_LOGIN_ALIAS=adminDVd2340@

# --- Fallback admin (only when DATABASE_URL is unset) ---
ADMIN_USERNAME=adminDvd
ADMIN_IDENTIFIER_ALT=adminDVd2340@

# --- Footer social (optional — full URLs to your profiles) ---
NEXT_PUBLIC_SOCIAL_YOUTUBE=
NEXT_PUBLIC_SOCIAL_DISCORD=
NEXT_PUBLIC_SOCIAL_INSTAGRAM=

# --- Vercel Blob ---
BLOB_READ_WRITE_TOKEN=

# First-time DB setup (with DATABASE_URL set):
#   npx prisma db push
#   npm run db:seed
