// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id           String   @id @default(cuid())
  username     String   @unique
  loginAlias   String?  @unique @map("login_alias")
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("admin_users")
}

/// Single row `id = "site"` — JSON payload matches SiteConfig (hero + sliders + success videos + free-course modules).
model SiteSettings {
  id        String   @id
  payload   Json
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("site_settings")
}

/// Marketing short links: /r/{slug} logs a row then redirects to destination + UTM params.
model UtmTrackedLink {
  id             String         @id @default(cuid())
  slug           String         @unique
  name           String
  destinationUrl String         @map("destination_url")
  utmSource      String         @map("utm_source")
  utmMedium      String         @map("utm_medium")
  utmCampaign    String         @map("utm_campaign")
  utmContent     String?        @map("utm_content")
  utmTerm        String?        @map("utm_term")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  clicks         UtmLinkClick[]

  @@map("utm_tracked_links")
}

model UtmLinkClick {
  id        String         @id @default(cuid())
  linkId    String         @map("link_id")
  link      UtmTrackedLink @relation(fields: [linkId], references: [id], onDelete: Cascade)
  createdAt DateTime       @default(now()) @map("created_at")

  @@index([linkId, createdAt])
  @@map("utm_link_clicks")
}
